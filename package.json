    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chart.js": "^4.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "vite": "^5.4.11"
  }
}
