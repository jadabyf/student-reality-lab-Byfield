{
  "name": "student-reality-lab-byfield",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-datasets.mjs",
    "build:pages": "vite build --mode github-pages && node scripts/copy-datasets.mjs",
    "preview": "vite preview",
    "generate-processed-data": "node scripts/generate-processed-data.mjs",
    "mcp:affordability": "node mcp/affordability-server.mjs",
